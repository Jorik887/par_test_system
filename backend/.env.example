# Paragraph Test Automation System (example)
# Copy to .env and fill values for your stand.

APP_ENV=prod

# Backend service DB (required)
BACKEND_DB_DSN=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/par_test_backend

# ISHD
ISHD_HOST=127.0.0.1
ISHD_PORT=50200
ISHD_HOST_ID=par_test_system
ISHD_SOFTWARE_NAME=Paragraph Test System
ISHD_LOGIN=
ISHD_PASSWORD=
ISHD_TARGET_HOST_ID=paragraf
ISHD_TARGET_HOST_IDS=paragraf
ISHD_TARGET_RECIPIENT=
ISHD_DEFAULT_PORT=8080
ISHD_REQUEST_TIMEOUT_SEC=8.0
ISHD_DOC_RESPONSE_TIMEOUT_SEC=35.0
ISHD_ACTION_DIRECT_TIMEOUT_SEC=1.0
ISHD_ACTION_RESULT_TIMEOUT_SEC=35.0

# Paragraph REST
PARAGRAPH_REST_BASE_URL=http://127.0.0.1:5000

# Paragraph DB (optional for fallback/report sections)
PARAGRAPH_DB_DSN=
PARAGRAPH_FILE_DIRS=C:\documents_files

# Optional encryption key
CRYPTO_KEY=
