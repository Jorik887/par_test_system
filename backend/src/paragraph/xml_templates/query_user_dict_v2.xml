<?xml version="1.0" encoding="UTF-8"?>
<document group="Пользовательские справочники" type="Запрос пользовательских справочников" alias="query_user_dict">

	<group alias="version">
		<!--Мажорная версия поднимается при потере обратной совместимости,
			минорая - при любых изменениях-->
		<spin_box name="Мажорная версия" alias="major" type="uint">2</spin_box>
		<spin_box name="Минорная версия" alias="minor" type="uint">0</spin_box>
	</group>
	<!-- Выбор по названиям справочников. Если поле не заполнено то будут выбраны все. -->
	<repeater alias="user_table_names" name="Названия справочников">
		<text_field name="Название справочника" alias="user_table_name" />
		
		<repeater alias="joined_tables" name="Связываемые таблицы">
			<text_field name="Название связываемого справочника" alias="joined_table_name" />
			<text_field name="Название ссылаемой колонки" alias="joined_column_name" />
		</repeater>		
	</repeater>

	<start_state id = "initial" name="Принято">
		<action button = "accept" state = "accepted" />
	</start_state >
	<state id="accepted" name="Выполняется">
		<action button="fail" state="failed">
			<text_field alias="reason" name="Сообщение"/>
		</action>
		<action button="complete" state="completed">
			<!-- При успешном выборе в ответ приходят все документы из выбраных справочников. -->
			<repeater alias="user_tables" name="Cправочники">
				<text_field alias="dict_name" name="Наименование"/>
				<text_field alias="dict_id" name="Идентификатор"/>
				<date alias="dict_last_modified" name="Дата и время последнего изменения" type="datetime" mask="dd.MM.yy HH:mm:ss" />
				<repeater alias="rows" name="Строки">
					<repeater alias="columns" name="Колонки">
						<text_field name = "Наименование колонки" alias="column_name"/>
						<combo_box name="Тип колонки" alias="column_type">
							<item>Текст</item>
							<item>Дата/время</item>
							<item>Логический тип</item>
							<item>Целое число</item>
							<item>Дробное число</item>
							<item>Координата</item>
							<item>Файл</item>
						</combo_box>
						<group alias="value">
							<text_field name = "Текстовое значение" alias="text_val"/>
							<date name = "Дата"  type="datetime" alias="date_val"/>
							<check_box name="Логическое значение" alias="check_val" checked="false"></check_box>
							<spin_box name = "Числовое значение" alias="spinbox_val" type="int" min="-4294967295" max="4294967295"/>
							<spin_box name = "Дробное значение" alias="spinbox_doubleval" type="double" min="-4294967295" max="4294967295"/>
							<coordinates name = "Координата" type="poi" alias="coordinates_val"/>
							<input_file name="Файл" alias="file_val"/>
						</group>
						<group alias="property">
							<date alias="val_last_modified" name="Дата и время обновления" type="datetime" mask="dd.MM.yy HH:mm:ss" />
						</group>
					</repeater>
				</repeater>
			</repeater>
		</action>
	</state>
	<final_state id="completed" name="Выполнено"/>
	<final_state id="failed" name="Ошибка"/>
</document>