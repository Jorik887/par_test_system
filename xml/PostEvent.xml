<?xml version="1.0" encoding="UTF-8"?>
<document group="Служебные" name="Событие поста" type="Состояние оборудования" alias="info"  module="paragraf">
	<!-- АРМ рабочее место, А-Интегратор -->
	<text_field name="Пост" alias="post"/>
	<!-- ПО, отправаляющее событие  -->
	<text_field name="АПС" alias="soft"/>
	<!-- Устройство, заполнение не обязательно -->
	<text_field name="Устройство" alias="device"/>
	<combo_box name="Событие" alias="event">
		<!-- Запуск ПО -->
		<item>Включение</item>
		<!-- Остановка ПО -->
		<item>Отключение</item>
		<!-- Запуск устройства, активное использование ПО -->
		<item>Активация</item>
		<!-- Остановка устройства, прекращение использования ПО -->
		<item>Деактивация</item>
		<!-- Ошибка сописание в примечании -->
		<item>Сбой</item>
		<!-- Описание действия в примечании в свободной форме -->
		<item>Действие оператора</item>
		<!-- Описание уведомлнения в примечании в свободной форме -->
		<item>Уведомление</item>
	</combo_box>
	<text_field name="Примечание" alias="description"/>
	<start_state id="start" name="Отправлено"/>
</document>

